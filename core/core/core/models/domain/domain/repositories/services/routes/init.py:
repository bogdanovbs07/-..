from routes.image_routes import router as image_router
from routes.user_routes import router as user_router
from routes.auth_routes import router as auth_router

__all__ = ["image_router", "user_router", "auth_router"]

from fastapi import APIRouter, Depends, HTTPException, UploadFile, File, Form
from sqlalchemy.orm import Session
from typing import List
from core.database import get_db
from repositories.image_repository import ImageRepository
from services.image_service import ImageService
from domain.schemas import ImageCreate, ImageResponse

router = APIRouter(prefix="/images", tags=["images"])

def get_image_service(db: Session = Depends(get_db)):
    image_repository = ImageRepository(db)
    return ImageService(image_repository)

@router.post("/", response_model=ImageResponse)
async def upload_image(
    file: UploadFile = File(...),
    description: str = Form(None),
    user_id: int = Form(None),
    service: ImageService = Depends(get_image_service)
):
    image_data = ImageCreate(filename=file.filename, description=description, user_id=user_id)
    result = service.create_image(image_data, file)
    if not result:
        raise HTTPException(status_code=400, detail="Could not upload image")
    return result

@router.get("/", response_model=List[ImageResponse])
def get_all_images(service: ImageService = Depends(get_image_service)):
    return service.get_all_images()

@router.get("/{image_id}", response_model=ImageResponse)
def get_image(image_id: int, service: ImageService = Depends(get_image_service)):
    """Получение изображения по ID"""
    result = service.get_image(image_id)
    if not result:
        raise HTTPException(status_code=404, detail="Image not found")
    return result

@router.put("/{image_id}/description")
def update_description(
    image_id: int, 
    description: str,
    service: ImageService = Depends(get_image_service)
):
    result = service.update_description(image_id, description)
    if not result:
        raise HTTPException(status_code=404, detail="Image not found")
    return result

@router.delete("/{image_id}")
def delete_image(image_id: int, service: ImageService = Depends(get_image_service)):
    result = service.delete_image(image_id)
    if not result:
        raise HTTPException(status_code=404, detail="Image not found")
    return {"message": "Image deleted successfully"}

